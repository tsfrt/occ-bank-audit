# -----------------------------------------------------------------------------
# Databricks workspace (CLI, bundle deploy, model serving API)
# Used for: databricks bundle, databricks postgres, model serving invocations
# -----------------------------------------------------------------------------
DATABRICKS_HOST="https://your-workspace.cloud.databricks.com"
DATABRICKS_TOKEN="dapi..."
# OAuth client credentials (used for SQL warehouse Statement Execution API auth)
DATABRICKS_CLIENT_ID=""
DATABRICKS_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# Lakebase database (separate from workspace credentials)
# Used for: Prisma / PostgreSQL connection to Lakebase branch endpoint only
# Must use postgresql:// and sslmode=require (Lakebase requires SSL).
# Default database name is databricks_postgres. See:
# https://docs.databricks.com/aws/en/oltp/projects/connection-strings
# -----------------------------------------------------------------------------
# Native password:
LAKEBASE_DATABASE_URL="postgresql://role_name:password@ep-xxx.databricks.com/databricks_postgres?sslmode=require"
# Or OAuth token (short-lived): postgresql://your-email@example.com@ep-xxx.databricks.com/databricks_postgres?sslmode=require

# -----------------------------------------------------------------------------
# Model serving (uses DATABRICKS_HOST + DATABRICKS_TOKEN for auth)
# -----------------------------------------------------------------------------
MODEL_SERVING_ENDPOINT_NAME="audit-analysis"

# -----------------------------------------------------------------------------
# Bank statement document review (SQL warehouse + UC volume file proxy)
# On Databricks Apps these are often set via bundle resources (see databricks.yml).
# -----------------------------------------------------------------------------
# SQL warehouse ID (UUID) for Statement Execution API — e.g. warehouse named 00vsdb
DATABRICKS_SQL_WAREHOUSE_ID=""

# Optional: volume base for resolving relative file_path values (deployed apps: BANK_STATEMENTS_VOLUME_BASE_PATH)
# BANK_STATEMENTS_VOLUME_BASE_PATH="/Volumes/main/tsfrt/occ"

# Optional: allowlist prefix for proxied files (default: {BANK_STATEMENTS_VOLUME_BASE_PATH}/bank_statements or /Volumes/main/tsfrt/occ/bank_statements)
# BANK_STATEMENT_ALLOWLIST_PREFIX="/Volumes/main/tsfrt/occ/bank_statements"

# Optional: allowlist prefix for meeting minute MP3 proxy (default: {BANK_STATEMENTS_VOLUME_BASE_PATH}/meeting_minutes)
# MEETING_MINUTES_ALLOWLIST_PREFIX="/Volumes/main/tsfrt/occ/meeting_minutes"
