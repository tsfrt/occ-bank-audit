# -----------------------------------------------------------------------------
# Databricks workspace (CLI, bundle deploy, model serving API)
# Used for: databricks bundle, databricks postgres, model serving invocations
# -----------------------------------------------------------------------------
DATABRICKS_HOST="https://your-workspace.cloud.databricks.com"
DATABRICKS_TOKEN="dapi..."

# -----------------------------------------------------------------------------
# Lakebase database (separate from workspace credentials)
# Used for: Prisma / PostgreSQL connection to Lakebase branch endpoint only
# Must use scheme postgresql:// or postgres:// (not prisma+postgres://)
# -----------------------------------------------------------------------------
LAKEBASE_DATABASE_URL="postgresql://user:password@lakebase-endpoint-host:5432/dbname?sslmode=require"
# Or: DATABASE_URL="postgresql://..."

# -----------------------------------------------------------------------------
# Model serving (uses DATABRICKS_HOST + DATABRICKS_TOKEN for auth)
# -----------------------------------------------------------------------------
MODEL_SERVING_ENDPOINT_NAME="audit-analysis"
